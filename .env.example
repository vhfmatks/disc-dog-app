# Supabase → Project Settings → Data API
# 이 파일을 .env 로 복사한 뒤 값을 채우고 `npm run config` 를 실행하세요.
#
# anon 키가 브라우저에 노출되는 것은 정상입니다. RLS가 방어선입니다.
# service_role 키는 절대 넣지 마세요 (gen-config.mjs가 감지하면 거부합니다).

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ── DB 마이그레이션 (Prisma) ──────────────────────────────────────
# 앱 런타임은 이 값을 쓰지 않습니다. prisma migrate 전용이며 프런트엔드 번들에도
# 들어가지 않습니다. Supabase → Project Settings → Database → Connection string.
#
# ⚠ 대시보드가 기본으로 보여주는 "Direct connection"(db.<ref>.supabase.co)을 쓰지 마세요.
#   그 호스트는 A 레코드 없이 AAAA(IPv6)만 있습니다. IPv4 전용 네트워크(사내망 대부분,
#   GitHub Actions 러너)에서는 그냥 P1001로 죽습니다.
#   → 대시보드에서 "Session pooler" 탭을 고르세요. 포트는 5432 그대로입니다.
#
# ⚠ transaction mode(6543)로도 마이그레이션은 돌지 않습니다. session mode여야 합니다.
#
# <region>은 프로젝트마다 다릅니다. 짐작하지 말고 대시보드에 적힌 그대로 쓰세요
# (예: ap-southeast-1, ap-northeast-2). 사용자 이름이 postgres.<ref> 형태인 것도 주의.
#
# DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# 마이그레이션을 새로 만들 때(npm run db:migrate:new)는 운영 DB 대신 로컬 Postgres를
# 가리키세요. Prisma가 shadow DB를 만들었다 지우기 때문입니다.
#   docker run -d --name dogtype-pg -e POSTGRES_PASSWORD=pw -p 55432:5432 postgres:15
#   DATABASE_URL=postgresql://postgres:pw@localhost:55432/postgres
DATABASE_URL=

# /admin에서 사용할 비밀번호. 프런트엔드 번들에는 포함되지 않으며,
# 같은 값을 Supabase Edge Function secret에도 설정해야 합니다.
#
# 참가자가 입력하는 "스페이스 비밀번호"와는 다릅니다. 그건 스페이스를 만든 사람이 정하고
# DB에 해시로만 저장되며, 여기에 쓸 값이 없습니다.
ADMIN_PASSWORD=CHANGE-THIS-TO-A-LONG-PASSWORD
